# .repomixignore — universal ignores applied to ALL repomix runs.
#
# Per-source includes/excludes are defined in .github/notebooklm-sources.yaml.
# This file contains only patterns that should NEVER appear in any source
# (build artifacts, caches, secrets, data files, etc.).
#
# Source: https://github.com/amulya-labs/ai-dev-foundry
# License: MIT (https://opensource.org/licenses/MIT)

# ── Python build / cache artifacts ──────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# ── JavaScript / Node.js ────────────────────────────────────────────────────
node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml
.next/
.nuxt/
.output/

# ── Virtual environments ────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Dependency lock files ────────────────────────────────────────────────────
poetry.lock
Pipfile.lock
Gemfile.lock
composer.lock
Cargo.lock

